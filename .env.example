# Supabase (backend). For frontend, also set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY (same values).
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_ANON_KEY=your_anon_key
# Optional: VITE_API_URL=http://localhost:8000 for frontend API base

# Google AI
GOOGLE_API_KEY=your_gemini_key
GOOGLE_CLOUD_PROJECT=your_project
GOOGLE_CLOUD_LOCATION=us-central1

# External Data Connectors
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
ACLED_USERNAME=your_acled_user
ACLED_PASSWORD=your_acled_pass
OPENWEATHER_API_KEY=your_openweather_key
FRED_API_KEY=your_fred_key
WTO_API_KEY=your_wto_key

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
backend_API_KEY=dev-key

# Agent Config — company/org for perception, risk runs, and UI (use ORG_TW_DEMO for Taiwan profile)
OMNI_COMPANY_ID=ORG_DEMO
DEFAULT_COMPANY_ID=ORG_DEMO
# Frontend: set in frontend/.env so UI and API calls use the same org
# VITE_DEFAULT_COMPANY_ID=ORG_DEMO

# Perception: we fetch from GDACS, ACLED, GDELT, WTO, OpenWeather, Alpha Vantage, FRED then normalize. Optional keys: OPENWEATHER_API_KEY, ALPHA_VANTAGE_API_KEY, FRED_API_KEY (ACLED_USERNAME/PASSWORD, WTO_API_KEY for conflict/trade). If no API keys and you want demo events anyway, set:
# PERCEPTION_FALLBACK_TO_GENERATE=true
APPROVAL_EXPIRY_HOURS=2
MAX_REASONING_ITERATIONS=3
RISK_THRESHOLD_NOTIFY=60
